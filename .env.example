# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram Chat ID (send /start to the bot, then use /chatid command)
CHAT_ID=your_chat_id_here

# Wallet P2P API Key
WALLET_API_KEY=your_wallet_api_key_here

# Polling interval in seconds (default: 30)
POLL_INTERVAL=30

# Pairs to monitor (comma-separated: CRYPTO-FIAT or CRYPTO-FIAT:SIDE)
# Sides: BUY, SELL (both monitored by default). Use + for multiple: USDT-RUB:BUY+SELL
# Examples: USDT-GEL (both sides), USDT-RUB:SELL (sell only)
MONITOR_PAIRS=USDT-GEL,USDT-USD,USDT-RUB:SELL

# Minimum price change percentage to trigger notification (default: 0.5)
PRICE_CHANGE_THRESHOLD=0.1

# Delay between API requests in milliseconds (default: 3000)
# Increase if you get 429 rate limit errors
REQUEST_DELAY=5000

# Max pages to fetch per pair+side (default: 3, each page = 50 offers)
# Reduces API calls for pairs with many offers (e.g. RUB with 400+)
MAX_PAGES=3

# Show notifications when offers are removed (default: true)
NOTIFY_REMOVED=true

# Only notify about NEW offers if they are in top N by price (0 = all, 5 = top 5 only)
NOTIFY_NEW_TOP_ONLY=0

# Filter by payment methods per pair (case-insensitive, empty = no filter)
# Format: PAIR:method1,method2;PAIR:method3,method4
# Use /payments bot command to see all available methods
# Example: USDT-USD:wise,revolut,zelle;USDT-GEL:bank_of_georgia,tbc_bank;USDT-RUB:sberbank,tinkoff
FILTER_PAYMENTS=USDT-USD:bankofgeorgia,tbcbank;USDT-GEL:bankofgeorgia,tbcbank,credobank;USDT-RUB:sbp,ozon,sberbankru,tinkoff,alfabank,raiffeisenru